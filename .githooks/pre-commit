#!/bin/sh

LOG_FILE="COMMIT_LOG.md"

if [ ! -f "$LOG_FILE" ]; then
  echo "Commit bloqué: le fichier $LOG_FILE est introuvable."
  exit 1
fi

if ! git diff --cached --name-only | grep -q "^$LOG_FILE$"; then
  echo "Commit bloqué: tu dois mettre a jour $LOG_FILE avant de commit."
  echo "Ajoute une entrée, puis fais: git add $LOG_FILE"
  exit 1
fi

CONTENT="$(git show ":$LOG_FILE")"

for FIELD in "Nom" "Nature" "Details" "Fichiers"; do
  if ! echo "$CONTENT" | grep -q "^\*\*$FIELD\*\*"; then
    echo "Commit bloqué: la section '$FIELD' est manquante dans $LOG_FILE."
    exit 1
  fi
done

echo "Journal de commit verifie."